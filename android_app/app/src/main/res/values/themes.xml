<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- 清新蓝绿主题 -->
    <style name="Theme.WaterTowerMonitor" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- 主题色 -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/text_on_primary</item>
        
        <!-- 辅助色 -->
        <item name="colorSecondary">@color/accent</item>
        <item name="colorSecondaryVariant">@color/primary_light</item>
        <item name="colorOnSecondary">@color/text_on_primary</item>
        
        <!-- 状态栏 -->
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        
        <!-- 背景 -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        
        <!-- 错误色 -->
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/text_on_primary</item>

        <!-- 圆角 -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.WaterTower.SmallComponent</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.WaterTower.MediumComponent</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.WaterTower.LargeComponent</item>
    </style>

    <!-- 圆角形状 -->
    <style name="ShapeAppearance.WaterTower.SmallComponent" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>

    <style name="ShapeAppearance.WaterTower.MediumComponent" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <style name="ShapeAppearance.WaterTower.LargeComponent" parent="ShapeAppearance.MaterialComponents.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>

    <!-- 按钮样式 -->
    <style name="Widget.WaterTower.Button" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">24dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.WaterTower.Button.Text" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="cornerRadius">24dp</item>
    </style>

    <!-- 卡片样式 -->
    <style name="Widget.WaterTower.CardView" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
        <item name="cardBackgroundColor">@color/card_background</item>
    </style>

    <!-- FAB 样式 -->
    <style name="Widget.WaterTower.FAB" parent="Widget.MaterialComponents.FloatingActionButton">
        <item name="backgroundTint">@color/primary</item>
        <item name="tint">@color/text_on_primary</item>
    </style>
</resources>
