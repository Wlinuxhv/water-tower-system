(kicad_pcb (version 20211014) (generator pcbnew)
  (general
    (thickness 1.6)
    (drawings 4)
    (modules 5)
    (nets 7)
  )
  (layers
    (0 "F.Cu" signal)
    (31 "B.Cu" signal)
    (37 "F.SilkS" user)
    (39 "F.Mask" user)
    (44 "Edge.Cuts" user)
  )
  (setup
    (pad_to_mask_clearance 0.1)
    (trace_width 0.25)
    (via_dia 0.6)
    (via_drill 0.3)
  )
  (net 0 "")
  (net 1 "+5V")
  (net 2 "GND")
  (net 3 "ADC_SIGNAL")
  (net 4 "MISSING_WATER")
  (net 5 "I2C_SDA")
  (net 6 "I2C_SCL")

  (net_class Default ""
    (clearance 0.2)
    (trace_width 0.25)
  )
  
  (net_class Power ""
    (clearance 0.3)
    (trace_width 0.8)
  )

  (module Connector:TerminalBlock_3P_5mm (layer F.Cu)
    (at 20 50)
    (fp_text reference J1 (at 0 -8) (layer F.SilkS))
    (fp_text value LIQUID_LEVEL (at 0 8) (layer F.Fab))
    (pad 1 thru_hole rect (at -5 0) (size 2.5 2.5) (drill 1.5) (net 1 "+5V"))
    (pad 2 thru_hole oval (at 0 0) (size 2.5 2.5) (drill 1.5) (net 2 "GND"))
    (pad 3 thru_hole oval (at 5 0) (size 2.5 2.5) (drill 1.5) (net 3 "ADC_SIGNAL"))
  )

  (module Connector:TerminalBlock_3P_5mm (layer F.Cu)
    (at 20 70)
    (fp_text reference J2 (at 0 -8) (layer F.SilkS))
    (fp_text value MISSING_WATER (at 0 8) (layer F.Fab))
    (pad 1 thru_hole rect (at -3.81 0) (size 2.0 2.0) (drill 1.2) (net 1 "+5V"))
    (pad 2 thru_hole oval (at 0 0) (size 2.0 2.0) (drill 1.2) (net 2 "GND"))
    (pad 3 thru_hole oval (at 3.81 0) (size 2.0 2.0) (drill 1.2) (net 4 "MISSING_WATER"))
  )

  (module Connector:RJ45_8P (layer F.Cu)
    (at 60 60)
    (fp_text reference J3 (at 0 -12) (layer F.SilkS))
    (fp_text value TO_CONTROLLER (at 0 12) (layer F.Fab))
    (pad 1 thru_hole rect (at -7.62 -5.08) (size 2.0 2.0) (drill 1.2) (net 1 "+5V"))
    (pad 2 thru_hole oval (at -7.62 -2.54) (size 2.0 2.0) (drill 1.2) (net 2 "GND"))
    (pad 3 thru_hole oval (at -7.62 0) (size 2.0 2.0) (drill 1.2) (net 3 "ADC_SIGNAL"))
    (pad 4 thru_hole oval (at -7.62 2.54) (size 2.0 2.0) (drill 1.2) (net 2 "GND"))
    (pad 5 thru_hole oval (at 7.62 -5.08) (size 2.0 2.0) (drill 1.2) (net 5 "I2C_SDA"))
    (pad 6 thru_hole oval (at 7.62 -2.54) (size 2.0 2.0) (drill 1.2) (net 6 "I2C_SCL"))
    (pad 7 thru_hole oval (at 7.62 0) (size 2.0 2.0) (drill 1.2) (net 4 "MISSING_WATER"))
    (pad 8 thru_hole oval (at 7.62 2.54) (size 2.0 2.0) (drill 1.2) (net 2 "GND"))
  )

  (module Capacitor_SMD:C_0805 (layer F.Cu)
    (at 45 50)
    (fp_text reference C1 (at 0 -1.55) (layer F.SilkS))
    (fp_text value 100nF (at 0 1.55) (layer F.Fab))
    (pad 1 smd rect (at -0.95 0) (size 0.7 0.9))
    (pad 2 smd rect (at 0.95 0) (size 0.7 0.9))
  )

  (module LED:LED_0805 (layer F.Cu)
    (at 45 70)
    (fp_text reference LED1 (at 0 -1.55) (layer F.SilkS))
    (fp_text value STATUS (at 0 1.55) (layer F.Fab))
    (pad A smd rect (at -0.95 0) (size 0.7 0.9) (net 1 "+5V"))
    (pad K smd rect (at 0.95 0) (size 0.7 0.9) (net 2 "GND"))
  )

  (gr_line (start 0 0) (end 80 0) (layer Edge.Cuts))
  (gr_line (start 80 0) (end 80 90) (layer Edge.Cuts))
  (gr_line (start 80 90) (end 0 90) (layer Edge.Cuts))
  (gr_line (start 0 90) (end 0 0) (layer Edge.Cuts))
  
  (gr_text "Water Sensor Probe" (at 40 45) (layer F.SilkS))
  (gr_text "V1.0" (at 70 80) (layer F.SilkS))

)
